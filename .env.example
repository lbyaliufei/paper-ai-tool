OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_RETRIES=2
OPENAI_STREAM=true
OPENAI_MAX_OUTPUT_TOKENS=8192
TRANSLATION_BATCH_SIZE=6
TRANSLATION_BATCH_MAX_CHARS=6000
TRANSLATION_MAX_WORKERS=2

# 默认输出到桌面。需要固定到其他目录时取消注释并填写。
# OUTPUT_DIR=~/Desktop

# 输出控制：默认只输出中文 Markdown 和总结 Markdown。
# 需要额外文件时设为 1。
OUTPUT_MARKDOWN=1
OUTPUT_SUMMARY=1
OUTPUT_HTML=0
OUTPUT_JSON=0
OUTPUT_EXCEL=0
OUTPUT_SOURCE_PDF=0
OUTPUT_DEBUG_FIGURES=0

# 默认关闭独立结构化抽取，省 token。
# OUTPUT_JSON=1 或 OUTPUT_EXCEL=1 时会自动开启。
RUN_STRUCTURED_EXTRACTION=0
